<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ================= Display ================= -->

    <style name="AppearanceFoundation.Large" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppearanceFoundation.Large.Secondary"
        parent="AppearanceFoundation.Large">
        <item name="android:textColor">?attr/colorSecondary</item>
    </style>


    <!-- ================= Title ================= -->

    <style name="AppearanceFoundation.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppearanceFoundation.Title.OnPrimary"
        parent="AppearanceFoundation.Title">
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>


    <!-- ================= Body ================= -->

    <style name="AppearanceFoundation.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>


    <!-- ================= Caption ================= -->

    <style name="AppearanceFoundation.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppearanceFoundation.Caption.Variant"
        parent="AppearanceFoundation.Caption">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="AppearanceFoundation.Caption.Primary"
        parent="AppearanceFoundation.Caption">
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <style name="AppearanceFoundation.Caption.OnPrimary"
        parent="AppearanceFoundation.Caption">
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>


    <!-- ================= Tiny ================= -->

    <style name="AppearanceFoundation.Tiny" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="AppearanceFoundation.Tiny.Bold"
        parent="AppearanceFoundation.Tiny">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppearanceFoundation.Tiny.Variant"
        parent="AppearanceFoundation.Tiny">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

</resources>